---
const { currentPath = '/' } = Astro.props;
const links = [
  { href: '/', label: 'Accueil' },
  { href: '/articles/', label: 'Articles' },
  { href: '/glossaire/', label: 'Glossaire' },
];
---
<header class="site-header">
  <div class="shell nav-shell">
    <a class="brand" href="/">
      <span class="brand-mark">IA</span>
      <span>IA, sans jargon</span>
    </a>

    <nav class="site-nav" aria-label="Navigation principale">
      {links.map((link) => (
        <a class:list={['nav-link', currentPath === link.href && 'is-active']} href={link.href}>{link.label}</a>
      ))}
    </nav>

    <a class="nav-button" href="/#rester-au-courant">Recevoir les prochains guides</a>
  </div>
</header>
