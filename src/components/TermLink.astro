---
import { getEntry } from 'astro:content';

interface Props {
  slug: string;
  label?: string;
  summary?: string;
}

const { slug, label, summary } = Astro.props;
const entry = await getEntry('glossary', slug);

if (!entry) {
  throw new Error(`Glossary entry not found for slug: ${slug}`);
}

const cardId = `term-${slug}-${Math.random().toString(36).slice(2, 8)}`;
const displayLabel = label ?? entry.data.title;
const displaySummary = summary ?? entry.data.shortDefinition ?? entry.data.summary;
---
<span class="term-inline" data-term-root>
  <button
    type="button"
    class="term-inline__trigger"
    aria-expanded="false"
    aria-controls={cardId}
    aria-haspopup="dialog"
    data-term-trigger
  >
    {displayLabel}
  </button>
  <span class="term-inline__card" id={cardId} hidden data-term-card role="dialog" aria-label={`Définition rapide : ${displayLabel}`}>
    <strong>{displayLabel}</strong>
    <span>{displaySummary}</span>
    <a href={`/glossaire/${slug}/`}>Voir dans le glossaire</a>
  </span>
</span>

<script is:inline>
  if (!window.__iaSansJargonTermsBound) {
    window.__iaSansJargonTermsBound = true;

    const closeAll = () => {
      document.querySelectorAll('[data-term-root]').forEach((root) => {
        const trigger = root.querySelector('[data-term-trigger]');
        const card = root.querySelector('[data-term-card]');
        if (trigger instanceof HTMLElement) trigger.setAttribute('aria-expanded', 'false');
        if (card instanceof HTMLElement) card.hidden = true;
      });
    };

    document.addEventListener('click', (event) => {
      const trigger = event.target instanceof Element ? event.target.closest('[data-term-trigger]') : null;
      const insideCard = event.target instanceof Element ? event.target.closest('[data-term-card]') : null;

      if (trigger) {
        const root = trigger.closest('[data-term-root]');
        const card = root?.querySelector('[data-term-card]');
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        closeAll();
        if (!isOpen && card instanceof HTMLElement) {
          trigger.setAttribute('aria-expanded', 'true');
          card.hidden = false;
        }
        return;
      }

      if (!insideCard) {
        closeAll();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeAll();
      }
    });
  }
</script>