---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const glossary = await getCollection('glossary');
  return glossary.map((term) => ({ params: { slug: term.data.slug }, props: { term } }));
}

const { term } = Astro.props;
const { Content } = await render(term);
const articles = await getCollection('articles');
const relatedArticles = term.data.relatedArticles
  .map((slug) => articles.find((article) => article.data.slug === slug))
  .filter(Boolean);
---
<BaseLayout title={`${term.data.title} — Glossaire IA, sans jargon`} description={term.data.summary}>
  <SiteHeader currentPath="/glossaire/" />

  <main class="shell page-section">
    <article class="article-layout glossary-layout">
      <header class="article-header">
        <p class="card-kicker">Glossaire · {term.data.category}</p>
        <h1>{term.data.title}</h1>
        <p class="article-summary">{term.data.summary}</p>
      </header>

      <div class="article-body prose">
        <p class="definition-pill">En bref : {term.data.shortDefinition}</p>
        <Content />
      </div>
    </article>

    {relatedArticles.length > 0 && (
      <section class="section-spacing">
        <div class="section-heading">
          <div>
            <p class="section-eyebrow">À lire ensuite</p>
            <h2>Articles liés à ce terme</h2>
          </div>
        </div>
        <div class="card-grid two-columns">
          {relatedArticles.map((article) => <ArticleCard article={article} compact />)}
        </div>
      </section>
    )}
  </main>

  <SiteFooter />
</BaseLayout>
