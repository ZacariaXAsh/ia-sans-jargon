---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import GlossaryCard from '../../components/GlossaryCard.astro';

const glossary = (await getCollection('glossary')).sort((a, b) => a.data.title.localeCompare(b.data.title, 'fr'));
---
<BaseLayout title="Glossaire — IA, sans jargon" description="Un petit glossaire simple pour les mots d’IA qu’on entend partout.">
  <SiteHeader currentPath="/glossaire/" />

  <main class="shell page-section">
    <section class="page-hero narrow-hero">
      <p class="section-eyebrow">Glossaire</p>
      <h1>Les mots qu’on entend partout, expliqués sans brouillard</h1>
      <p>
        Pas d’autolink agressif, pas de dictionnaire géant. Juste les premiers termes qui aident vraiment à lire les articles sans décrocher.
      </p>
    </section>

    <section class="card-grid three-columns">
      {glossary.map((term) => <GlossaryCard term={term} />)}
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
