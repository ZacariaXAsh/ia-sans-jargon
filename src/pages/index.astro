---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ArticleCard from '../components/ArticleCard.astro';
import GlossaryCard from '../components/GlossaryCard.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import ValuePillars from '../components/ValuePillars.astro';
import HomeHero from '../components/HomeHero.astro';
import HomeContent, { frontmatter as home } from '../content/pages/home.md';

if (!home) {
  throw new Error('Home content entry not found');
}

const allArticles = await getCollection('articles');
const allGlossary = await getCollection('glossary');

const featuredArticles = home.featuredArticles
  .map((slug) => allArticles.find((article) => article.data.slug === slug))
  .filter(Boolean);

const featuredGlossary = home.featuredGlossary
  .map((slug) => allGlossary.find((term) => term.data.slug === slug))
  .filter(Boolean);

const articleBySlug = (slug) => allArticles.find((article) => article.data.slug === slug);

const entryPoints = [
  {
    title: 'J’ai peur de faire n’importe quoi',
    body: 'Commencez par apprendre à reconnaître ce qui est sans risque, ce qu’il faut vérifier, et ce qu’il vaut mieux éviter au début.',
    href: `/articles/${articleBySlug('comment-savoir-si-un-usage-de-l-ia-est-sur-ou-risque')?.data.slug || ''}/`,
    cta: 'Voir les bons premiers usages',
    tone: 'caution',
  },
  {
    title: 'Je veux comprendre sans mots compliqués',
    body: 'Un point de départ clair pour ne plus confondre IA, chatbot, prompt, hallucination ou moteur de langage.',
    href: `/articles/${articleBySlug('ia-chatbot-llm-quelle-difference-en-pratique')?.data.slug || ''}/`,
    cta: 'Clarifier les mots utiles',
    tone: 'brand',
  },
  {
    title: 'Je veux tester un truc utile tout de suite',
    body: 'Le meilleur début n’est pas spectaculaire : c’est un petit test sur téléphone, facile à vérifier et sans enjeu lourd.',
    href: `/articles/${articleBySlug('premier-test-ia-sans-risque-sur-telephone')?.data.slug || ''}/`,
    cta: 'Faire un test simple',
    tone: 'safe',
  },
];

const quickChecks = [
  'Réécrire un message pour qu’il soit plus clair et plus poli.',
  'Retirer les infos privées avant de coller quoi que ce soit dans un chat.',
  'Relire le résultat comme un brouillon, pas comme une réponse finale.',
];

const quickTopics = [
  articleBySlug('comment-demander-de-laide-a-lia-sans-parler-technique'),
  articleBySlug('avant-de-croire-une-reponse-de-lia-verifiez-ces-5-points'),
  articleBySlug('comment-garder-la-main-sur-le-resultat-final'),
].filter(Boolean);
---
<BaseLayout title={home.title} description={home.description}>
  <SiteHeader currentPath="/" />

  <main>
    <HomeHero
      eyebrow={home.eyebrow}
      title={home.heroTitle}
      summary={home.heroSummary}
      reassurance={home.reassurance}
      primaryHref={`/articles/${featuredArticles[0]?.data.slug || ''}/`}
      secondaryHref="/articles/"
      quickChecks={quickChecks}
    />

    <ValuePillars />

    <section class="shell section-spacing editorial-intro">
      <div class="prose prose--home">
        <HomeContent />
      </div>
    </section>

    <section class="shell section-spacing">
      <div class="section-heading">
        <div>
          <p class="section-eyebrow">Par où entrer ?</p>
          <h2>Choisissez le point de départ qui vous ressemble le plus</h2>
        </div>
      </div>

      <div class="card-grid three-columns entry-grid">
        {entryPoints.map((entry) => (
          <article class={`card entry-card entry-card--${entry.tone}`}>
            <h3>{entry.title}</h3>
            <p>{entry.body}</p>
            <a class="text-link" href={entry.href}>{entry.cta}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="shell section-spacing quick-test-section">
      <div class="quick-test card">
        <div>
          <p class="section-eyebrow">Test simple en 2 minutes</p>
          <h2>Commencez par une tâche courte, utile, et facile à vérifier</h2>
          <p>
            Le meilleur premier pas n’est pas de demander quelque chose d’impressionnant. C’est de prendre un message,
            une note ou un petit brouillon, puis de voir ce que l’outil améliore sans changer le sens.
          </p>
        </div>

        <div class="quick-test__steps">
          <div class="quick-step">
            <span>1</span>
            <p>Choisissez un texte court que vous comprenez déjà.</p>
          </div>
          <div class="quick-step">
            <span>2</span>
            <p>Demandez une version plus claire, plus courte ou plus polie.</p>
          </div>
          <div class="quick-step">
            <span>3</span>
            <p>Relisez, corrigez si besoin, puis gardez le dernier mot.</p>
          </div>
        </div>

        <div class="quick-test__actions">
          <a class="button-primary" href={`/articles/${articleBySlug('premier-test-ia-sans-risque-sur-telephone')?.data.slug || ''}/`}>
            Suivre le test guidé
          </a>
          <a class="button-secondary" href={`/articles/${articleBySlug('comment-demander-de-laide-a-lia-sans-parler-technique')?.data.slug || ''}/`}>
            Apprendre à demander simplement
          </a>
        </div>
      </div>
    </section>

    <section class="shell section-spacing">
      <div class="section-heading">
        <div>
          <p class="section-eyebrow">À lire ensuite</p>
          <h2>Des guides courts pour commencer sans se tromper</h2>
        </div>
        <a class="text-link" href="/articles/">Voir tout</a>
      </div>

      <div class="card-grid two-columns">
        {featuredArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </section>

    <section class="shell section-spacing living-grid">
      <div class="card snack-panel">
        <p class="section-eyebrow">Repères utiles</p>
        <h2>Ce qui aide tout de suite</h2>
        <div class="snack-list">
          {quickTopics.map((article) => (
            <a class="snack-link" href={`/articles/${article.data.slug}/`}>
              <strong>{article.data.title}</strong>
              <span>{article.data.summary}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="card snack-panel snack-panel--calm">
        <p class="section-eyebrow">Bon réflexe</p>
        <h2>Safe, à vérifier, à éviter</h2>
        <ul class="traffic-list">
          <li><strong>Safe :</strong> résumer, reformuler, transformer des notes en liste.</li>
          <li><strong>À vérifier :</strong> chiffres, faits, actualité, règles officielles.</li>
          <li><strong>À éviter :</strong> données privées, santé, argent, décisions sensibles sans contrôle humain.</li>
        </ul>
      </div>
    </section>

    <section class="shell section-spacing">
      <div class="section-heading">
        <div>
          <p class="section-eyebrow">Glossaire utile</p>
          <h2>Les mots qu’on entend partout, expliqués sans brouillard</h2>
        </div>
        <a class="text-link" href="/glossaire/">Ouvrir le glossaire</a>
      </div>

      <div class="glossary-lead card">
        <div>
          <p class="glossary-lead__title">Le mot du jour</p>
          <h3>Prompt</h3>
          <p>
            Ce n’est pas une formule magique. C’est simplement la consigne que vous donnez à l’outil.
            Plus elle est claire, plus le résultat a des chances d’être utile.
          </p>
        </div>
        <a class="text-link" href="/glossaire/prompt/">Voir la définition complète</a>
      </div>

      <div class="card-grid three-columns">
        {featuredGlossary.map((term) => <GlossaryCard term={term} />)}
      </div>
    </section>

    <section class="shell section-spacing waitlist-section waitlist-section--secondary">
      <WaitlistForm
        source="editorial-home"
        title="Recevoir les prochains guides utiles"
        description="Si le ton du site vous aide, vous pouvez laisser votre email pour recevoir les prochains contenus quand ils sortent."
      />
    </section>
  </main>

  <SiteFooter />
</BaseLayout>